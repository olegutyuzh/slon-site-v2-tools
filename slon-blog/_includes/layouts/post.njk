---
layout: layouts/base.njk
isPost: true
---

{# ===== Метатеги для OG/title — UA-версія за замовчуванням ===== #}
{% set pageTitle = title.uk %}
{% set ogTitle = title.uk %}
{% set description = lede.uk if lede else '' %}

{#
  Пріоритет вибору OG-зображення:
  1. og_image (явно задане у frontmatter — спеціально оптимізоване, 1200×630)
  2. перше фото з масиву photos[]
  3. старе поле photo (зворотна сумісність)
#}
{% set photo = og_image or (photos[0].src if photos and photos.length) or photo %}

{# ===== HERO посту ===== #}
<section class="bio-hero">
  <div class="bio-hero-inner">

    <div class="story-attribution">
      <img src="/img/igor-portrait-small.png" 
          alt="Ігор «Слон» Утюж" 
          class="story-attribution__avatar">
      <span class="story-attribution__text">
      <span data-i18n="stories_filter_{{ category }}">{{ ('stories_filter_' + category) | t('uk') }}</span>
    </div>

    <h1 class="bio-hero-title">
      <span data-lang-content="uk">{{ title.uk }}</span>
      <span data-lang-content="en">{{ title.en }}</span>
    </h1>

    <div class="bio-hero-years">
      <span data-lang-content="uk">{{ date | dateLocalized('uk') }}</span>
      <span data-lang-content="en">{{ date | dateLocalized('en') }}</span>
    </div>

    {% if lede %}
    <p class="story-hero-lede">
      <span data-lang-content="uk">{{ lede.uk }}</span>
      <span data-lang-content="en">{{ lede.en }}</span>
    </p>
    {% endif %}

    {% if author %}
    <div class="story-attribution-author">
      —&nbsp;<span data-lang-content="uk">{{ author.uk }}</span><span data-lang-content="en">{{ author.en }}</span>
    </div>
    {% endif %}    

      {# <div class="bio-hero-divider"></div> #}
  </div>
</section>

{# ===== ОСНОВНИЙ ТЕКСТ ===== #}
<section class="section bio-chapter">
  <div class="section-inner bio-chapter-inner">
    <div class="bio-content">

      {#
        ===== ФОТО =====
        Підтримуємо два формати у frontmatter:

        1) НОВИЙ: масив photos[]
           photos:
             - src: /img/stories/foo.jpg
               caption:
                 uk: "Підпис українською"
                 en: "English caption"
               portrait: true   # опційно
             - src: /img/stories/bar.jpg

        2) СТАРИЙ (fallback): поле photo + photo_caption + photo_portrait
      #}

      {% if photos and photos.length %}
        {# Новий формат: масив #}
        {% for p in photos %}
          <figure class="story-figure {% if p.portrait %}story-figure--portrait{% endif %}">
            <div class="story-figure-img">
              <img src="{{ p.src }}" alt="{{ p.alt or title.uk }}" loading="lazy" />
        </div>
            {% if p.caption %}
        <figcaption class="story-figure-caption">
              <span data-lang-content="uk">{{ p.caption.uk }}</span>
              <span data-lang-content="en">{{ p.caption.en }}</span>
        </figcaption>
        {% endif %}
      </figure>
        {% endfor %}
      {% elif photo %}
        {# Старий формат: одне фото — для зворотної сумісності #}
        <figure class="story-figure {% if photo_portrait %}story-figure--portrait{% endif %}">
          <div class="story-figure-img">
            <img src="{{ photo }}" alt="{{ title.uk }}" loading="lazy" />
          </div>
          {% if photo_caption %}
          <figcaption class="story-figure-caption">
            <span data-lang-content="uk">{{ photo_caption.uk }}</span>
            <span data-lang-content="en">{{ photo_caption.en }}</span>
          </figcaption>
          {% endif %}
        </figure>
      {% endif %}

      {# Тіло поста: рендеримо обидві мови як два <div>, lang.js покаже потрібну #}
      <div data-lang-content="uk">
        {{ body_uk | markdown | safe }}
      </div>
      <div data-lang-content="en">
        {{ body_en | markdown | safe }}
      </div>

      {# ===== Поширення в соцмережах ===== #}
      {% include "partials/share.njk" %}
      
      {# ===== Навігація: попередня / наступна ===== #}
      <div class="bio-divider"></div>

      <nav class="post-nav">
        {% set prevPost = collections.posts | getPreviousCollectionItem(page) %}
        {% set nextPost = collections.posts | getNextCollectionItem(page) %}

        {% if prevPost %}
        <a href="{{ prevPost.url }}" class="post-nav-link post-nav-prev">
          <span class="post-nav-label">← <span data-i18n="story_nav_prev">Попередня</span></span>
          <span class="post-nav-title">
            <span data-lang-content="uk">{{ prevPost.data.title.uk }}</span>
            <span data-lang-content="en">{{ prevPost.data.title.en }}</span>
          </span>
        </a>
        {% endif %}

        {% if nextPost %}
        <a href="{{ nextPost.url }}" class="post-nav-link post-nav-next">
          <span class="post-nav-label"><span data-i18n="story_nav_next">Наступна</span> →</span>
          <span class="post-nav-title">
            <span data-lang-content="uk">{{ nextPost.data.title.uk }}</span>
            <span data-lang-content="en">{{ nextPost.data.title.en }}</span>
          </span>
        </a>
        {% endif %}
      </nav>

      <div class="post-back">
        <a href="/stories.html" class="btn" data-i18n="story_back_to_list">← Усі історії</a>
      </div>

    </div>
  </div>
</section>
