<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/biography.css" />
  <link rel="stylesheet" href="/blog.css" />
  <link rel="stylesheet" href="/voices.css" />
  <link rel="stylesheet" href="/share.css" />
  <link rel="stylesheet" href="/bottom_menu.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap&subset=cyrillic">

  <title>{{ pageTitle | default('Історії') }} — Ігор «Слон» Утюж</title>

  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
  {% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}

  {# ===== Open Graph ===== #}
  {% if ogTitle %}<meta property="og:title" content="{{ ogTitle }}">{% endif %}
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:type" content="{% if isPost %}article{% else %}website{% endif %}">
  <meta property="og:url" content="https://slon.life{{ page.url }}">
  <meta property="og:site_name" content="Slon">
  {% if photo %}
    <meta property="og:image" content="https://slon.life{{ photo }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    {% if ogTitle %}<meta property="og:image:alt" content="{{ ogTitle }}">{% endif %}
  {% endif %}
  <meta property="og:locale" content="uk_UA">
  <meta property="og:locale:alternate" content="en_US">

  {# ===== Twitter Card ===== #}
  <meta name="twitter:card" content="summary_large_image">
  {% if ogTitle %}<meta name="twitter:title" content="{{ ogTitle }}">{% endif %}
  {% if description %}<meta name="twitter:description" content="{{ description }}">{% endif %}
  {% if photo %}<meta name="twitter:image" content="https://slon.life{{ photo }}">{% endif %}

  <!-- GoatCounter analytics -->
  <script data-goatcounter="https://slon.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
        
</head>

<body class="page">

  {# ===== HEADER ===== #}
  <header class="header">
    <div class="header-inner">

      <a href="/index.html" class="header-logo" aria-label="SLON">
        <div class="header-logo-mark">
          <img src="/img/symbol-slon.png" alt="Символ Слон" class="logo-elephant" loading="lazy" />
        </div>
        SLON
      </a>

      <nav class="header-nav" aria-label="Основна навігація">
        <a href="/memories.html" data-i18n="menu_memories">Спогади</a>
        <a href="/stories.html" data-i18n="menu_stories" class="{% if isStoriesIndex or isPost %}is-active{% endif %}"{% if isStoriesIndex or isPost %} aria-current="page"{% endif %}>Історії</a>
        <a href="/biography.html" data-i18n="menu_biography">Життєпис</a>
      </nav>

      <div class="header-lang">
        <button type="button" data-lang="uk" class="is-active">UA</button>
        <button type="button" data-lang="en">EN</button>
      </div>

    </div>
  </header>

  {{ content | safe }}

  {# ===== FOOTER ===== #}
  <footer class="footer">
    <div class="footer-inner">

      <div class="footer-left">
        <div data-i18n="footer_left_text_1">Сайт-пам'ять про Ігоря «Слона» Утюжа.</div>
        <div data-i18n="footer_left_text_2">Створено родиною та друзями. 2024 — 2026.</div>
      </div>

      <div class="footer-right">
        <div class="footer-lang" data-i18n="footer_right_text">Мова</div>
        <div class="footer-lang">
          <span class="is-active" data-lang="uk" role="button" tabindex="0">UA</span>
          <span data-lang="en" role="button" tabindex="0">EN</span>
        </div>
      </div>

    </div>
  </footer>

  {# ===== НИЖНЯ МОБІЛЬНА НАВІГАЦІЯ ===== #}
  <nav class="bottom-nav" aria-label="Мобільна навігація">
    <a href="/index.html" class="bottom-nav-item">
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11c0-3.3 2.7-6 6-6h3c3.3 0 6 2.7 6 6v4"/>
        <path d="M4 11v6"/>
        <path d="M7 17v3"/>
        <path d="M19 15v5"/>
        <path d="M16 17v3"/>
        <path d="M10 11c0 1.5 1 2.5 2 3v4"/>
        <path d="M12 18l-1 1"/>
        <circle cx="8" cy="9" r="0.5" fill="currentColor"/>
      </svg>
      <span class="bottom-nav-label" data-i18n="menu_home">Головна</span>
    </a>

    <a href="/memories.html" class="bottom-nav-item">
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="bottom-nav-label" data-i18n="menu_memories">Спогади</span>
    </a>

    <a href="/stories.html" class="bottom-nav-item {% if isStoriesIndex or isPost %}is-active{% endif %}"{% if isStoriesIndex or isPost %} aria-current="page"{% endif %}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 6c2-1 5-1.5 8 0v13c-3-1.5-6-1-8 0z"/>
        <path d="M22 6c-2-1-5-1.5-8 0v13c3-1.5 6-1 8 0z"/>
        <path d="M10 6v13"/>
      </svg>
      <span class="bottom-nav-label" data-i18n="menu_stories">Історії</span>
    </a>

    <a href="/biography.html" class="bottom-nav-item">
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4h12a3 3 0 0 1 3 3v13H7a3 3 0 0 1-3-3V4z"/>
        <path d="M4 17a3 3 0 0 1 3-3h12"/>
        <path d="M9 8h6M9 12h4"/>
      </svg>
      <span class="bottom-nav-label" data-i18n="menu_biography">Життєпис</span>
    </a>
  </nav>
  <script src="/lang.js"></script>
  <script src="/share.js"></script> 
</body>
</html>
