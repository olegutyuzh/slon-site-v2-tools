<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/biography.css" />
  <link rel="stylesheet" href="/blog.css" />
  <link rel="stylesheet" href="/voices.css" />
  <link rel="stylesheet" href="/share.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&family=Caveat:wght@500;600&display=swap&subset=cyrillic">

  <title>{{ pageTitle | default('Історії') }} — Слон</title>
  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
  {% if canonical %}<link rel="canonical" href="{{ canonical }}" />{% endif %}

  {# ===== OG ===== #}
  {% if ogTitle %}<meta property="og:title" content="{{ ogTitle }}">{% endif %}
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  {% if photo %}<meta property="og:image" content="https://slon.life{{ photo }}">{% endif %}
  <meta property="og:locale" content="uk_UA">
  <meta property="og:locale:alternate" content="en_US">
</head>

<body class="page">

  {# ===== HEADER ===== #}
  <header class="header">
    <div class="header-inner">

      <a href="/index.html" class="header-logo" aria-label="SLON">
        <div class="header-logo-mark">
          <img src="/img/symbol-slon.png" alt="Символ Слон" class="logo-elephant" />
        </div>
        SLON
      </a>

      <nav class="header-nav">
        <a href="/index.html#about" data-i18n="menu_about">Про Ігоря</a>
        <a href="/index.html#war-path" data-i18n="menu_warpath">Шлях воїна</a>
        <a href="/index.html#life" data-i18n="menu_life">Фрагменти життя</a>
        <a href="/index.html#symbols" data-i18n="menu_symbols">Символіка</a>
        <a href="/memories.html" data-i18n="menu_memories">Спогади</a>
        <a href="/biography.html" data-i18n="menu_biography">Біографія</a>
        <a href="/stories.html" data-i18n="menu_stories" class="{% if isStoriesIndex or isPost %}is-active{% endif %}">Історії</a>
      </nav>

      <div class="header-lang">
        <button type="button" data-lang="uk" class="is-active">UA</button>
        <button type="button" data-lang="en">EN</button>
      </div>

    </div>
  </header>

  {{ content | safe }}

  {# ===== FOOTER ===== #}
  <footer class="footer">
    <div class="footer-inner">

      <div class="footer-left">
        <div data-i18n="footer_left_text_1">Сайт-пам'ять про Ігоря «Слона» Утюжа.</div>
        <div data-i18n="footer_left_text_2">Створено родиною та друзями. 2024 — 2026.</div>
      </div>

      <div class="footer-right">
        <div class="footer-lang" data-i18n="footer_right_text">Мова</div>
        <div class="footer-lang">
          <span class="is-active" data-lang="uk" role="button" tabindex="0">UA</span>
          <span data-lang="en" role="button" tabindex="0">EN</span>
        </div>
      </div>

    </div>
  </footer>

  <script src="/lang.js"></script>
  <script src="/share.js"></script> 
</body>
</html>
